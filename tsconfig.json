{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@screens/*": ["src/screens/*"],
      "@hooks/*": ["src/hooks/*"],
      "@constants/*": ["src/constants/*"],
      "@data/*": ["src/data/*"],
      "@storage/*": ["src/storage/*"],
      "@navigation/*": ["src/navigation/*"],
      "@/types": ["src/types/index"]
    }
  }
}
